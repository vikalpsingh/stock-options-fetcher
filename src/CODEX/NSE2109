# --------------------- Option chain helpers ---------------------


def _nse_session() -> requests.Session:
    """Create an NSE-friendly session with warm-up requests."""
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/120.0.0.0 Safari/537.36",
        "Accept-Language": "en-US,en;q=0.9",
        "Accept": "application/json, text/javascript, */*; q=0.01",
        "Referer": "https://www.nseindia.com/",
        "Connection": "keep-alive",
    }
    session = requests.Session()
    session.headers.update(headers)
    try:
        session.get("https://www.nseindia.com", timeout=10)
        time.sleep(0.7)
    except Exception:
        pass
    return session


def fetch_option_chain(symbol: str) -> dict:
    """Fetch option chain data for a symbol from NSE."""
    url = f"https://www.nseindia.com/api/option-chain-equities?symbol={symbol}"
    with _nse_session() as session:
        try:
            session.get(f"https://www.nseindia.com/get-quotes/derivatives?symbol={symbol}", timeout=10)
            time.sleep(0.7)
        except Exception:
            pass
        resp = session.get(url, timeout=20)
        resp.raise_for_status()
        return resp.json()


def _parse_expiry_dates(expiry_list: List[str]) -> List[date]:
    """Parse expiry date strings into date objects, sorted ascending."""
    out = []
    for s in expiry_list or []:
        try:
            out.append(datetime.strptime(s, "%d-%b-%Y").date())
        except Exception:
            continue
    return sorted(out)


def pick_current_and_next_month(
    expiries: List[date], today: Optional[date] = None
) -> Tuple[Optional[date], Optional[date]]:
    """Select last expiry in current and next calendar month."""
    if today is None:
        today = date.today()
    if not expiries:
        return None, None

    cur_month_expiries = [d for d in expiries if d.month == today.month and d >= today]
    next_month_num = (today.month % 12) + 1
    next_month_year = today.year + (1 if today.month == 12 else 0)
    next_month_expiries = [d for d in expiries if d.month == next_month_num and d.year == next_month_year]

    cur_m = max(cur_month_expiries) if cur_month_expiries else None
    nxt_m = max(next_month_expiries) if next_month_expiries else None
    return cur_m, nxt_m


def get_otm_option_premiums(records: dict, underlying: float, expiry: str, lot_size: int):
    """Pick closest listed strikes meeting 10% OTM thresholds and return prices + lot premiums."""
    strikes = sorted({
        float(item["strikePrice"])
        for item in records.get("data", [])
        if item.get("expiryDate") == expiry and item.get("strikePrice") is not None
    })

    target_call = underlying * 1.10
    target_put = underlying * 0.90

    call_candidates = [s for s in strikes if s >= target_call]
    put_candidates = [s for s in strikes if s <= target_put]

    call_strike = min(call_candidates) if call_candidates else None
    put_strike = max(put_candidates) if put_candidates else None

    call_prem = call_total = None
    put_prem = put_total = None

    if call_strike is not None:
        row = next(
            (r.get("CE") for r in records.get("data", [])
             if r.get("expiryDate") == expiry and float(r.get("strikePrice")) == call_strike and r.get("CE")),
            None
        )
        if row:
            call_prem = row.get("lastPrice")
            call_total = call_prem * lot_size if call_prem is not None else None

    if put_strike is not None:
        row = next(
            (r.get("PE") for r in records.get("data", [])
             if r.get("expiryDate") == expiry and float(r.get("strikePrice")) == put_strike and r.get("PE")),
            None
        )
        if row:
            put_prem = row.get("lastPrice")
            put_total = put_prem * lot_size if put_prem is not None else None

    return call_strike, call_prem, call_total, put_strike, put_prem, put_total


# --------------------- Probability helpers ---------------------


def remove_outliers_iqr(data: pd.DataFrame, column: str, k: float = 1.5) -> pd.DataFrame:
    """Remove outliers from data based on IQR method."""
    q1 = data[column].quantile(0.25)
    q3 = data[column].quantile(0.75)
    iqr = q3 - q1
    lower = q1 - k * iqr
    upper = q3 + k * iqr
    return data[(data[column] >= lower) & (data[column] <= upper)].reset_index(drop=True)


def compute_probabilities(
    symbol: str,
    months_back: int = 24,
    alpha: float = 0.85,
    weight_scheme: str = "exp",
    iqr_k: float = 1.5
) -> Optional[dict]:
    """Compute probability of price increase or decrease based on historical data."""
    end_date = datetime.today()
    start_date = end_date - pd.DateOffset(months=months_back)
    data = equity_history(symbol, "EQ", start_date.strftime("%d-%m-%Y"), end_date.strftime("%d-%m-%Y"))
    if data is None or data.empty:
        return None

    data["YearMonth"] = pd.to_datetime(data["CH_TIMESTAMP"]).dt.to_period("M")
    data["log_return"] = np.log(data["CH_CLOSING_PRICE"] / data["CH_CLOSING_PRICE"].shift(1))

    monthly = data.groupby("YearMonth").agg(
        close=("CH_CLOSING_PRICE", "last"),
        vol=("log_return", lambda x: np.std(x.dropna(), ddof=1) * np.sqrt(21)),
    ).reset_index()
    monthly["pct_change"] = monthly["close"].pct_change() * 100
    monthly.dropna(subset=["pct_change"], inplace=True)
    monthly.reset_index(drop=True, inplace=True)

    trimmed = remove_outliers_iqr(monthly, "pct_change", k=iqr_k)
    if len(trimmed) < 3:
        return None

    n = len(trimmed)
    if weight_scheme == "exp":
        weights = np.array([alpha ** (n - 1 - i) for i in range(n)])
    else:
        weights = np.ones(n)
    weights /= weights.sum()

    weighted_positive = np.sum(w for w, chg in zip(weights, trimmed["pct_change"]) if chg > 0)
    weighted_negative = np.sum(w for w, chg in zip(weights, trimmed["pct_change"]) if chg < 0)
    total_weight = weighted_positive + weighted_negative

    prob_inc = weighted_positive / total_weight if total_weight else 0
    prob_dec = weighted_negative / total_weight if total_weight else 0
    direction = "Increase" if prob_inc >= prob_dec else "Decrease"

    return {
        "prob_increase": float(prob_inc),
        "prob_decrease": float(prob_dec),
        "direction": direction,
    }


# --------------------- I/O helpers ---------------------


def expiry_to_filename(expiry: str) -> str:
    dt_ = datetime.strptime(expiry, "%d-%b-%Y")
    return dt_.strftime("%b_%Y") + "_predictions.csv"


# --------------------- Main ---------------------


def main():
    os.makedirs("analysis_outputs", exist_ok=True)
    combined_rows = []

    for symbol, name, lot in SHARES:
        try:
            # 1) Compute probabilities
            prob = compute_probabilities(symbol)
            if prob is None:
                print(f"{symbol}: Not enough data for probability calculation. Skipping probability fields.")

            # 2) Fetch option chain
            chain = fetch_option_chain(symbol)
            records = chain.get("records", {})
            underlying = records.get("underlyingValue")
            expiry_strs = records.get("expiryDates", [])
            if not underlying or not expiry_strs:
                print(f"{symbol}: No option-chain or expiry data. Skipping.")
                continue

            expiries = _parse_expiry_dates(expiry_strs)
            cur_m, nxt_m = pick_current_and_next_month(expiries)

            pairs = []
            if cur_m:
                pairs.append(("Current", cur_m.strftime("%d-%b-%Y")))
            if nxt_m:
                pairs.append(("Next", nxt_m.strftime("%d-%b-%Y")))

            if not pairs:
                print(f"{symbol}: No monthly expiries (current/next) found. Skipping.")
                continue

            # 3) For each expiry, calculate 10% OTM call/put premiums
            for label, expiry_str in pairs:
                cs, c_prem, c_total, ps, p_prem, p_total = get_otm_option_premiums(
                    records, underlying, expiry_str, lot
                )

                row = {
                    "Symbol": symbol,
                    "Name": name,
                    "Lot Size": lot,
                    "Underlying": underlying,
                    "Cycle": label,  # Current / Next
                    "Expiry": expiry_str,
                    "10%OTM Call Strike": cs,
                    "Call LTP": c_prem,
                    "Call Premium (Lot)": c_total,
                    "10%OTM Put Strike": ps,
                    "Put LTP": p_prem,
                    "Put Premium (Lot)": p_total,
                }

                if prob:
                    row.update({
                        "Probability Increase": prob["prob_increase"],
                        "Probability Decrease": prob["prob_decrease"],
                        "Predicted Direction": prob["direction"],
                        "Direction Leg (if used)": "CALL" if prob["direction"] == "Increase" else "PUT",
                        "Chosen Strike (dir)": cs if prob["direction"] == "Increase" else ps,
                        "Chosen LTP (dir)": c_prem if prob["direction"] == "Increase" else p_prem,
                        "Chosen Premium (Lot) (dir)": c_total if prob["direction"] == "Increase" else p_total,
                    })
                else:
                    row.update({
                        "Probability Increase": None,
                        "Probability Decrease": None,
                        "Predicted Direction": None,
                        "Direction Leg (if used)": None,
                        "Chosen Strike (dir)": None,
                        "Chosen LTP (dir)": None,
                        "Chosen Premium (Lot) (dir)": None,
                    })

                combined_rows.append(row)

                print(
                    f"{symbol} [{label} {expiry_str}]: "
                    f"CALL K={cs} LTP={c_prem} PremLot={c_total} | "
                    f"PUT K={ps} LTP={p_prem} PremLot={p_total}"
                )

        except Exception as e:
            print(f"{symbol}: error {e}")

    if not combined_rows:
        print("\nNo results to save.")
        return

    # Create combined DataFrame
    df_all = pd.DataFrame(combined_rows)

    # Save per-month expiry files and combined file
    df_all["__monthfile__"] = pd.to_datetime(df_all["Expiry"], format="%d-%b-%Y").dt.strftime("%b_%Y")
    for mname, chunk in df_all.groupby("__monthfile__"):
        out_csv = os.path.join("analysis_outputs", f"{mname}_predictions.csv")
        chunk.drop(columns=["__monthfile__"]).to_csv(out_csv, index=False)
        print(f"✓ Saved {out_csv}")

    combined_csv = os.path.join("analysis_outputs", "combined_predictions.csv")
    df_all.drop(columns=["__monthfile__"]).to_csv(combined_csv, index=False)
    print(f"✓ Saved {combined_csv}")


if __name__ == "__main__":
    main()
