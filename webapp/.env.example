# Optional Phase-1 affiliate/deep-link templates.
# If omitted, Plan & Book uses public partner search pages without affiliate attribution.
REDBUS_AFFILIATE_BASE_URL=https://www.redbus.in/search
BOOKING_AFFILIATE_BASE_URL=https://www.booking.com/searchresults.html

# Bus
REDBUS_AFFILIATE_ID=
REDBUS_CAMPAIGN_PREFIX=indiankumbh

# BOOKING_AFFILIATE_ID is used server-side by /go/booking to build Booking.com affiliate URLs.
# Add this after Booking.com Affiliate Partner Programme approval.
# Hotels
BOOKING_AFFILIATE_ID=
BOOKING_LABEL_PREFIX=indiankumbh

# Flights
EASEMYTRIP_AFFILIATE_ID=
EASEMYTRIP_CAMPAIGN_PREFIX=indiankumbh
YATRA_AFFILIATE_ID=
YATRA_CAMPAIGN_PREFIX=indiankumbh

# Train
IRCTC_AFFILIATE_ID=
IRCTC_CAMPAIGN_PREFIX=indiankumbh

# Packages / leads
THRILLOPHILIA_PARTNER_ID=
LEAD_NOTIFICATION_EMAIL=admin@indiankumbh.com

# Public affiliate campaign identifiers used by src/data/affiliateLinks.ts.
# Leave blank until the relevant affiliate programme has approved the account.
# NEXT_PUBLIC_BOOKING_AFFILIATE_ID should only be used if a client-side widget requires it.
# Prefer server-side /go/booking so the app can validate, track and redirect safely.
NEXT_PUBLIC_BOOKING_AFFILIATE_ID=
NEXT_PUBLIC_YATRA_AFFILIATE_ID=

# Required for /admin/package-enquiries. Use a long unique password.
ADMIN_PASSWORD=
