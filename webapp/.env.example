# Optional Phase-1 affiliate/deep-link templates.
# If omitted, Plan & Book uses public partner search pages without affiliate attribution.
REDBUS_AFFILIATE_BASE_URL=https://www.redbus.in/search
BOOKING_AFFILIATE_BASE_URL=https://www.booking.com/searchresults.html

# Public affiliate campaign identifiers used by src/data/affiliateLinks.ts.
# Leave blank until the relevant affiliate programme has approved the account.
NEXT_PUBLIC_BOOKING_AFFILIATE_ID=
NEXT_PUBLIC_YATRA_AFFILIATE_ID=

# Required for /admin/package-enquiries. Use a long unique password.
ADMIN_PASSWORD=
